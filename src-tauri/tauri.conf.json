{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nanazon Share",
  "version": "2.1.0",
  "identifier": "com.nanazon.share",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Nanazon Share",
        "width": 600,
        "height": 650,
        "resizable": false,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../scripts/puppeteer-service.cjs",
      "../scripts/node"
    ]
  }
}
